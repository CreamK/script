        {
          "id": "id77_ql_port",
          "name": "青龙端口",
          "val": "",
          "type": "number"
        },
        {
          "id": "id77_ql_clientId",
          "name": "青龙 Client Id",
          "val": "",
          "type": "text"
        },
        {
          "id": "id77_ql_clientSecret",
          "name": "青龙 Client Secret",
          "val": "",
          "type": "text"
        },
        {
          "id": "id77_des_fileName",
          "name": "目的文件名",
          "val": "",
          "type": "text",
          "placeholder": "QX取iCloud的Scripts文件夹文件，NodeJS取运行同级路径下的文件"
